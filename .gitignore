# Local media (music & character art) — kept out of the public repo.
# Folders themselves are preserved via .gitkeep so artisan / npm scripts
# don't fail on first clone.
/storage/app/private/audio/*
!/storage/app/private/audio/.gitkeep
/storage/app/public/ancients/*
!/storage/app/public/ancients/.gitkeep
!/storage/app/public/ancients/bg/
/storage/app/public/ancients/bg/*
